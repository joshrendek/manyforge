{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "mf-provider": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ManyForge LLM Provider",
      "options": {
        "baseURL": "{env:LLM_BASE_URL}",
        "apiKey": "{env:LLM_API_KEY}"
      }
    }
  },
  "model": "mf-provider/{env:LLM_MODEL}",
  "permission": {
    "edit": "deny",
    "bash": "deny",
    "webfetch": "deny"
  }
}
