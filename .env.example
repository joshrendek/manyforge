# ManyForge runtime configuration (12-factor). Copy to .env; never commit secrets.

# HTTP
MANYFORGE_ADDR=:8080
LOG_LEVEL=info

# PostgreSQL — the application role MUST be a non-superuser, non-BYPASSRLS role.
MANYFORGE_DATABASE_URL=postgres://manyforge_app:devpassword@localhost:5432/manyforge?sslmode=disable

# Auth (EdDSA key ring; rotate by adding keys, never reuse). Paths to PEM keys.
MANYFORGE_JWT_ISSUER=manyforge
MANYFORGE_JWT_AUDIENCE=manyforge-api
MANYFORGE_JWT_ACTIVE_KID=k1
MANYFORGE_JWT_KEYS_DIR=./secrets/jwt
MANYFORGE_ACCESS_TOKEN_TTL=15m

# Outbound email (dev mailer logs to stdout when unset)
MANYFORGE_SMTP_URL=

# Networking — CIDR(s) of trusted proxies allowed to set the client IP.
MANYFORGE_TRUSTED_PROXY_CIDR=127.0.0.1/32
