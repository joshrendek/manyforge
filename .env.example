# ManyForge runtime configuration (12-factor). Copy to .env; never commit secrets.

# HTTP
MANYFORGE_ADDR=:8080
LOG_LEVEL=info

# PostgreSQL — the application role MUST be a non-superuser, non-BYPASSRLS role.
MANYFORGE_DATABASE_URL=postgres://manyforge_app:devpassword@localhost:55432/manyforge?sslmode=disable

# Auth (EdDSA key ring; rotate by adding keys, never reuse). Paths to PEM keys.
MANYFORGE_JWT_ISSUER=manyforge
MANYFORGE_JWT_AUDIENCE=manyforge-api
MANYFORGE_JWT_ACTIVE_KID=k1
MANYFORGE_JWT_KEYS_DIR=./secrets/jwt
MANYFORGE_ACCESS_TOKEN_TTL=15m

# Outbound email (dev mailer logs to stdout when unset)
MANYFORGE_SMTP_URL=

# Networking — CIDR(s) of trusted proxies allowed to set the client IP.
MANYFORGE_TRUSTED_PROXY_CIDR=127.0.0.1/32

# --- Support desk (spec 002) ---

# Built-in inbound SMTP receiver. An in-process component of the single binary
# (NOT a second service). Empty disables it; the webhook adapter still works.
# Ports <1024 need root/CAP_NET_BIND_SERVICE — use :2525 locally.
MANYFORGE_SMTP_ADDR=:2525

# Inbound provider webhook adapter. HMAC-SHA256 secret used to verify the
# X-MF-Signature header (constant-time). Required to accept webhooks.
MANYFORGE_INBOUND_WEBHOOK_SECRET=dev-inbound-secret-change-me

# Reply-token HMAC key. Mints/verifies the unforgeable threading reply token
# carried in the outbound Reply-To (support+{token}@domain). MUST be separate
# from the webhook + JWT secrets (purpose separation — a leak of one must not
# forge the others). Empty in dev falls back to header-only threading.
MANYFORGE_INBOUND_REPLY_TOKEN_SECRET=dev-reply-token-secret-change-me

# Attachment blob backend (SL-E). Local filesystem for self-host, or an
# S3-compatible URL. Empty disables attachment storage.
MANYFORGE_BLOB_URL=file:///tmp/manyforge-blobs
#   S3-compatible alternative:
#   MANYFORGE_BLOB_URL=s3://manyforge-attachments?region=us-east-1&endpoint=http://localhost:9000

# Platform-hosted domain that auto-provisioned system inbound addresses live on.
MANYFORGE_INBOUND_SYSTEM_DOMAIN=inbound.localhost

# DKIM signing key for verified custom sending identities (FR-013). Optional in
# dev — unset means verified-outbound is unsigned locally.
MANYFORGE_DKIM_KEY_PATH=./secrets/dkim/default.private

# Size caps (bytes). Defaults: 30 MiB inbound message, 25 MiB per attachment.
MANYFORGE_INBOUND_MAX_BYTES=31457280
MANYFORGE_ATTACHMENT_MAX_BYTES=26214400

# Inbound-ingest + outbound-send rate limits (token bucket; FR-018/FR-020).
MANYFORGE_INGEST_RATE_RPS=2
MANYFORGE_INGEST_RATE_BURST=20
MANYFORGE_OUTBOUND_RATE_RPS=2
MANYFORGE_OUTBOUND_RATE_BURST=20
